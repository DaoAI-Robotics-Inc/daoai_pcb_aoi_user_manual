msgid "铝电解电容"
msgstr "Aluminum electrolytic capacitor"

#: ../../source/complete_user_guide/features/create_product.rst:133
#: ../../source/complete_user_guide/features/create_product.rst:140
msgid "电阻器（片式）"
msgstr "Chip resistor"

#: ../../source/complete_user_guide/features/create_product.rst:134
msgid "SOIC / SOP / TSOP / TSSOP / MSOP（细间距：检测翘脚、短少、桥连、形变）"
msgstr ""
"SOIC / SOP / TSOP / TSSOP / MSOP (fine pitch: lifted leads, missing or short"
" leads, bridges, deformation)"

#: ../../source/complete_user_guide/features/create_product.rst:135
#: ../../source/complete_user_guide/features/create_product.rst:138
msgid "电容器（片式）"
msgstr "Chip capacitor"

#: ../../source/complete_user_guide/features/create_product.rst:136
msgid "电阻器（片式电阻）"
msgstr "Chip resistor"

#: ../../source/complete_user_guide/features/create_product.rst:137
#: ../../source/complete_user_guide/features/create_product.rst:148
#: ../../source/complete_user_guide/features/create_product.rst:161
msgid "钽电容"
msgstr "Tantalum capacitor"

#: ../../source/complete_user_guide/features/create_product.rst:139
msgid "QFP（四边引脚：翘起、桥连、缺失、偏移、脚形不规则）"
msgstr ""
"QFP (four-sided leads: lifted leads, bridges, missing leads, offset, "
"irregular lead shape)"

#: ../../source/complete_user_guide/features/create_product.rst:141
#: ../../source/complete_user_guide/features/create_product.rst:145
#: ../../source/complete_user_guide/features/create_product.rst:153
msgid "多层片式电感器"
msgstr "Multilayer chip inductor"

#: ../../source/complete_user_guide/features/create_product.rst:142
#: ../../source/complete_user_guide/features/create_product.rst:146
msgid "LED"
msgstr "LED"

#: ../../source/complete_user_guide/features/create_product.rst:143
msgid "铝电解电容（焊脚 / 焊盘润湿）"
msgstr "Aluminum electrolytic capacitor (lead / pad wetting)"

#: ../../source/complete_user_guide/features/create_product.rst:147
#: ../../source/complete_user_guide/features/create_product.rst:176
msgid "SOT / SOD"
msgstr "SOT / SOD"

#: ../../source/complete_user_guide/features/create_product.rst:150
msgid "LED（部分带极性标识）"
msgstr "LED (some with polarity marking)"

#: ../../source/complete_user_guide/features/create_product.rst:151
msgid "排阻（电阻网络）"
