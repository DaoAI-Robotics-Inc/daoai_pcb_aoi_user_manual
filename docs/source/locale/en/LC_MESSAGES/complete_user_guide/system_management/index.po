msgstr ""
"Whether the color-ratio threshold can be updated from statistics, "
"improving segmentation and defect-filter reliability."

#: ../../source/complete_user_guide/system_management/index.rst:264
#: ../../source/complete_user_guide/system_management/index.rst:295
msgid "AI更新覆盖（ai_update_override）"
msgstr "AI Update Override (``ai_update_override``)"

